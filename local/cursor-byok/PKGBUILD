pkgname=cursor-byok
pkgver=0.0.39
pkgrel=1
pkgdesc="Infinite BYOK in Cursor - 自由选择模型，集成自定义模型 API"
arch=('x86_64')
url="https://github.com/leookun/cursor-byok"
license=('custom')
depends=('glibc')
source=("${pkgname}-${pkgver}-linux-amd64.tar.gz::${url}/releases/download/v${pkgver}/${pkgname}-${pkgver}-linux-amd64.tar.gz"
        "${pkgname}.desktop")
sha256sums=('f17589c7ed0a1640901c8b65f9873ce91abaab09a8cd9e11a3b3e1009e8d1ab7'
            'd72558cad1b94fdb1c75d79ed02ebac473f6683716df494cee52bfefec10636c')

options=(!strip)

package() {
    install -Dm755 "${srcdir}/Cursor助手" "${pkgdir}/usr/bin/cursor-byok"
    install -Dm644 "${srcdir}/${pkgname}.desktop" "${pkgdir}/usr/share/applications/${pkgname}.desktop"
}
