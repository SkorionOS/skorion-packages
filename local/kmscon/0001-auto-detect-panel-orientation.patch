From 9c39fa5d6d2edadb934a3ef9ef6929223658393b Mon Sep 17 00:00:00 2001
From: honjow <honjow311@gmail.com>
Date: Thu, 23 Apr 2026 19:04:31 +0800
Subject: [PATCH 2/2] build: make v9.3.4 buildable with bundled libtsm

v9.3.4's meson.build requires libtsm >= 4.5.0 but the libtsm wrap was
left pinned at v4.4.2 and kmscon's own src/shl_dlist.h does not expose
the shl_dlist_next/_prev helpers that libtsm 4.5.0 sources rely on. On
systems whose distro libtsm is still 4.4.x meson falls back to the
wrap and the build then fails because libtsm sources pick up kmscon's
older shl_dlist.h first on the include path.

Bump the wrap revision to v4.5.0 and add the two missing macros to
src/shl_dlist.h, mirroring the libtsm definition. When the system
libtsm catches up to >= 4.5.0 the wrap is not used and these macros
become a no-op carry.
---
 src/shl_dlist.h         | 10 ++++++++++
 subprojects/libtsm.wrap |  2 +-
 2 files changed, 11 insertions(+), 1 deletion(-)

diff --git a/src/shl_dlist.h b/src/shl_dlist.h
index 83cd233..9e70384 100644
--- a/src/shl_dlist.h
+++ b/src/shl_dlist.h
@@ -102,6 +102,16 @@ static inline bool shl_dlist_empty(struct shl_dlist *head)
 
 #define shl_dlist_last(head, type, member) shl_dlist_entry((head)->prev, type, member)
 
+/* libtsm >= 4.5.0 uses these typed iter helpers. Keep them in sync with
+ * subprojects/libtsm/src/shared/shl_dlist.h so that libtsm sources compiled
+ * via the meson wrap pick up a compatible definition (kmscon's src/ comes
+ * first on the include path). */
+#define shl_dlist_next(iter, head, member) \
+	((iter)->member.next == (head) ? NULL : shl_dlist_entry((iter)->member.next, typeof(*iter), list))
+
+#define shl_dlist_prev(iter, head, member) \
+	((iter)->member.prev == (head) ? NULL : shl_dlist_entry((iter)->member.prev, typeof(*iter), list))
+
 #define shl_dlist_for_each(iter, head) for (iter = (head)->next; iter != (head); iter = iter->next)
 
 #define shl_dlist_for_each_but_one(iter, start, head)                                              \
diff --git a/subprojects/libtsm.wrap b/subprojects/libtsm.wrap
index 4e6af2e..1d00fa3 100644
--- a/subprojects/libtsm.wrap
+++ b/subprojects/libtsm.wrap
@@ -2,7 +2,7 @@
 directory = libtsm
 
 url = https://github.com/kmscon/libtsm
-revision = v4.4.2
+revision = v4.5.0
 depth = 1
 
 [provide]
-- 
