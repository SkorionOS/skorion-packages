pkgname=kmscon
pkgver=9.3.3
pkgrel=1
pkgdesc='Kernel Mode Setting (KMS) and DRM based virtual Console Emulator'
arch=('x86_64')
url='https://github.com/kmscon/kmscon'
license=('MIT')
backup=('etc/kmscon/kmscon.conf')
depends=(
  bash
  glib2
  glibc
  libdrm
  libtsm
  libxkbcommon
  systemd-libs
  zlib
)
makedepends=(
  check
  docbook-xsl
  freetype2
  git
  libxslt
  linux-api-headers
  libglvnd
  meson
  pango
)
optdepends=(
  'fontconfig: for freetype font rendering'
  'inotify-tools: for kmscon-launch-gui waiting mechanism'
  'libglvnd: for accelerated video output'
  'pango: for pango font rendering'
)
source=(
  git+${url}.git#tag=v${pkgver}
  "0001-auto-detect-panel-orientation.patch"
)
sha256sums=('5f7622b954416c5cc1ecdc69597c240a1b32fb0102a3d41264c981e327e931eb'
            '60fb0838a043f32e86714f26f31a3c2f270de1239ae45efed00b904b8434f939')

prepare() {
    cd ${srcdir}/${pkgname}

    local src
    for src in "${source[@]}"; do
        [[ $src = *.patch ]] || continue
        patch -p1 < "${srcdir}"/$src
    done
}

build() {
  arch-meson "$pkgname" build
  meson compile -C build
}

package() {
  meson install -C build --destdir="$pkgdir"
  install -Dm644 $pkgname/COPYING "$pkgdir/usr/share/licenses/$pkgname/COPYING"
}
